class B : A {
  sus  [ | _ := 'hello'. ]
  bar: [ :y | ]
  fun [|
    _ := self barr: 1. "najde se v B"
    _ := self weee: 3. "najde se v A"
    _ := self gro: 5. "metoda se nenajde v B ani v A, vytvoří se atribut 'gro'"
    _ := self fooo: 8. "pokus o vytvoření atributu, ale nadtřída definuje 'foo' -> CHYBA 54"
    _ := self fooo. "invokuje metodu foo v A"
    a := self sus. "najde se metoda v B (má přednost před atributem vytvořeným z 'foo')"
  ]
}

class A : Object {
  foo  [ | 
    _ := 'test' print.
    a := self gro. 
    _ := 'end foo' print.
 ]
  bar: [ :x | ]
  wee: [ :z | ]
  asString [ | _ := 'gghhh' print.]
}

class Main : Object {
  run [|
    "Bezparametrické selektory"
    o := B new. "vytvoří instanci A"
    _ := o fun. "metoda se najde v třídě A"
  ]
}