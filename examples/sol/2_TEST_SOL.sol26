class A : Integer {
  foo [|]
  bar: [ :x | r := x plus: 176. ]
}

class B : A {
  foo_2 [|]
  bar: [ :x | r := x plus: 180. ]
}

class AA : Object {
  m: [ :x | _ := x print. ]
  r [ | _ := self print. ]
}

class BB : AA { "B dědí z A, redefinuje metodu m"
  m: [ 
    :x | 
      _ := super m: 'ahyj'.
      _ := x print. 
  ]
"super -> použije se implementace z A"
}
class CC : BB {
  u [ | _ := self m: super. ]
  print [ | _ :='bar' print. ]
}

class Main : Object {
  run [|
    cc := CC new.
    _ := cc m: 'fuu'.
    _ := cc u.
    _ := cc r.
  ]

  fooo: [ :x |
  "s proměnnou 'u' se nijak dál nepracuje, ale výsledek zaslání
  zprávy 'plus:' bude vrácen jako výsledek volání metody 'foo'"
  u := x plus: 10.
  ]

  bar_3: [ :x | r := ( x plus: 1 ) plus: 3. ]
}