class Main : Integer {
  run [|
    "-123"
    i := Integer from: -123.
    _ := (i asString) print.

    "456"
    s := String from: '456'.
    _ := s print.

    "nil"
    n := Nil from: 7.
    _ := (n asString) print.

    "false"
    b := n identicalTo: 3.
    _ := (b asString) print.

    "true"
    v := n identicalTo: Nil.
    _ := (v asString) print.

    "1"
    i := Integer from: true.
    _ := (i asString) print.

    "0"
    i := Integer from: false.
    _ := (i asString) print.

    "0"
    i := Integer from: nil.
    _ := (i asString) print.
  ]
}
