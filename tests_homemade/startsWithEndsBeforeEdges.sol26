class Main : Integer {
  run [|
    "nil"
    r := 'abcdef' startsWith: 0 endsBefore: 3.
    _ := (r asString) print.
    _ := ' == nil\n' print.

    ""
    r := 'abcdef' startsWith: 3 endsBefore: 3.
    _ := r print.
    _ := ' == \n' print.

    "def"
    r := 'abcdef' startsWith: 4 endsBefore: 99.
    _ := r print.
    _ := ' == def\n' print.

    "nil"
    r := 'abcdef' startsWith: -2 endsBefore: 3.
    _ := (r asString) print.
    _ := ' == nil\n' print.

    ""
    r := 'abcdef' startsWith: 5 endsBefore: 1.
    _ := r print.
    _ := ' == \n' print.
  ]
}
