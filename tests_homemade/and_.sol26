class Main : Integer {
  run [|
    "true"
    r := true and: (5 equalTo: 5).
    _ := (r asString) print.

    "false"
    r := false and: false.
    _ := (r asString) print.

    "false"
    r := false and: (5 equalTo: 5).
    _ := (r asString) print.

    "true"
    r := (5 equalTo: 5) and: (5 equalTo: 5).
    _ := (r asString) print.






  ]
}
