class Main : Integer {
  run [|
    "42"
    r := 6 multiplyBy: 7.
    _ := (r asString) print.
    _ := ' == 42\n' print.
    "0"
    r := 6 multiplyBy: 0.
    _ := (r asString) print.
    _ := ' == 0\n' print.
    "-12"
    r := 3 multiplyBy: -4.
    _ := (r asString) print.
    _ := ' == -12\n' print.
  ]
}
