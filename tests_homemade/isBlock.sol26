class Box : Integer {
}
class Main : Integer {
  run [|
    "true"
    blk := [| r := 1. ].
    r := blk isBlock.
    _ := (r asString) print.

    "false"
    r := 1 isBlock.
    _ := (r asString) print.
    "false"
    r := 'b' isBlock.
    _ := (r asString) print.
    "false"
    r := nil isBlock.
    _ := (r asString) print.
    "false"
    r := true isBlock.
    _ := (r asString) print.
    "false"
    r := false isBlock.
    _ := (r asString) print.
    "false"
    o := Box new.
    r := o isBlock.
    _ := (r asString) print.
  ]
}
