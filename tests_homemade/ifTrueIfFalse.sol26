class Main : Integer {
  run [|
    "T"
    r := true ifTrue: [ | r := 'T'. ] ifFalse: [ | r := 'F'. ].
    _ := (r asString) print.
    "F"
    r := false ifTrue: [ | r := 'T'. ] ifFalse: [ | r := 'F'. ].
    _ := (r asString) print.

    "10"
    x := 10.
    r := true ifTrue: [ | r := x. ] ifFalse: [ | r := 99. ].
    _ := (r asString) print.

    "99"
    r := false ifTrue: [ | r := x. ] ifFalse: [ | r := 99. ].
    _ := (r asString) print.
  ]
}
