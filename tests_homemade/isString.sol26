class Box : Integer {
}
class Main : Integer {
  run [|
    "false"
    r := 0 isString.
    _ := (r asString) print.
    "false"
    r := '' isString.
    _ := (r asString) print.
    "false"
    r := nil isString.
    _ := (r asString) print.
    "false"
    r := true isString.
    _ := (r asString) print.
    "false"
    r := false isString.
    _ := (r asString) print.
    "false"
    o := Box new.
    r := o isString.
    _ := (r asString) print.
  ]
}
