class Box : Integer {
}
class Main : Integer {
  run [|
    "false"
    r := 0 isNil.
    _ := (r asString) print.
    _ := ' == false\n' print.
    "false"
    r := 'x' isNil.
    _ := (r asString) print.
    _ := ' == false\n' print.
    "true"
    r := nil isNil.
    _ := (r asString) print.
    _ := ' == true\n' print.
    "false"
    r := true isNil.
    _ := (r asString) print.
    _ := ' == false\n' print.
    "false"
    r := false isNil.
    _ := (r asString) print.
    _ := ' == false\n' print.
    "false"
    o := Box new.
    r := o isNil.
    _ := (r asString) print.
    _ := ' == false\n' print.
  ]
}
