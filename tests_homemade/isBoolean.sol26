class Box : Integer {
}
class Main : Integer {
  run [|
    "false"
    r := 0 isBoolean.
    _ := (r asString) print.
    "false"
    r := 'x' isBoolean.
    _ := (r asString) print.
    "false"
    r := nil isBoolean.
    _ := (r asString) print.
    "true"
    r := true isBoolean.
    _ := (r asString) print.
    "true"
    r := false isBoolean.
    _ := (r asString) print.
    "false"
    o := Box new.
    r := o isBoolean.
    _ := (r asString) print.
  ]
}
